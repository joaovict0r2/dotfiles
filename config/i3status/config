# i3status — earthy, polido. Editar como UTF-8.
general {
        colors = true
        color_good     = "#9aac6f"
        color_degraded = "#c0a268"
        color_bad      = "#b57766"
        interval = 5
}

order += "volume master"
order += "cpu_temperature 11"
order += "memory"
order += "disk /"
order += "battery all"
order += "tztime local"

volume master {
        format       = " %volume"
        format_muted = " muted"
        device       = "pulse"
}

cpu_temperature 11 {
        format = " CPU %degrees°C"
        # coretemp "Package id 0" via hwmon — thermal_zone11 (x86_pkg_temp/ACPI)
        # jitters +/-10C sample to sample even at idle; this hwmon reading is
        # the stable, accurate one (same value `sensors` reports).
        # NOTE: hwmon index can shift after a kernel/driver update — if this
        # path stops existing, find the new one with:
        #   grep -l coretemp /sys/class/hwmon/hwmon*/name
        path   = "/sys/class/hwmon/hwmon5/temp1_input"
}

memory {
        format             = "󰍛 RAM %used"
        threshold_degraded = "10%"
        format_degraded    = "󰍛 RAM %used"
}

disk "/" {
        format = " %avail"
}

battery all {
        format         = "%status %percentage"
        format_down    = ""
        status_chr     = ""
        status_bat     = ""
        status_full    = ""
        status_unk     = ""
        low_threshold  = 15
        threshold_type = percentage
        integer_battery_capacity = true
}

tztime local {
        format = " %d/%m %H:%M"
}
